# ============================================
# NEXUS — Environment Configuration
# Copy to .env and fill in your keys
# ============================================

# Azure OpenAI (recommended for Microsoft Hackathon)
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_VERSION=2024-08-01-preview

# OR: Standard OpenAI
OPENAI_API_KEY=your_openai_key_here

# Pinecone (for agent memory)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX=nexus-memory

# App Config
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5500
MAX_AGENT_STEPS=30
AGENT_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
